<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- ================= 1. 手机端主页 ================= -->
    <LinearLayout android:id="@+id/home_view" android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" android:gravity="center" android:padding="32dp">

        <ImageView android:layout_width="80dp" android:layout_height="80dp" android:src="@drawable/ic_logo" android:layout_marginBottom="16dp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="长夜腕阅" android:textColor="#D0BCFF" android:textSize="28sp" android:textStyle="bold" android:letterSpacing="0.1" android:layout_marginBottom="8dp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="上传端" android:textColor="#AAAAAA" android:textSize="14sp" android:layout_marginBottom="48dp"/>

        <!-- 传输文件按钮 -->
        <LinearLayout android:id="@+id/btn_home_transfer" android:layout_width="match_parent" android:layout_height="64dp" android:background="@drawable/bg_home_item" android:gravity="center" android:layout_marginBottom="16dp" android:clickable="true" android:focusable="true">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="📡" android:textSize="24sp" android:layout_marginEnd="12dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="局域网传书" android:textColor="#E6E0E9" android:textSize="18sp" android:textStyle="bold"/>
        </LinearLayout>

        <!-- 关于应用按钮 -->
        <LinearLayout android:id="@+id/btn_home_about" android:layout_width="match_parent" android:layout_height="64dp" android:background="@drawable/bg_home_item" android:gravity="center" android:clickable="true" android:focusable="true">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="ℹ️" android:textSize="24sp" android:layout_marginEnd="12dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="关于应用" android:textColor="#E6E0E9" android:textSize="18sp" android:textStyle="bold"/>
        </LinearLayout>
    </LinearLayout>

    <!-- ================= 2. 传书控制层 (预留给你现有的传输逻辑) ================= -->
    <LinearLayout android:id="@+id/transfer_view" android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" android:gravity="center" android:padding="32dp" android:visibility="gone" android:background="#000000">

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="请保持手表端与手机在同一 WiFi 下" android:textColor="#888888" android:textSize="14sp" android:layout_marginBottom="32dp"/>

        <Button android:id="@+id/btn_select_file" android:layout_width="match_parent" android:layout_height="60dp" android:text="选择电子书 (EPUB/TXT)" android:backgroundTint="#D0BCFF" android:textColor="#332D41" android:textSize="16sp" android:textStyle="bold" android:layout_marginBottom="24dp"/>

        <TextView
            android:id="@+id/tv_file_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="等待选择文件..."
            android:textColor="#E6E0E9"
            android:textSize="14sp"
            android:gravity="center"
            android:lineSpacingExtra="6dp"/>
    </LinearLayout>

    <!-- ================= 3. 专属名片关于层 ================= -->
    <LinearLayout android:id="@+id/about_view" android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" android:gravity="center" android:padding="32dp" android:visibility="gone" android:background="#000000">

        <ImageView android:layout_width="64dp" android:layout_height="64dp" android:src="@drawable/ic_logo" android:layout_marginBottom="12dp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="长夜腕阅" android:textColor="#D0BCFF" android:textSize="22sp" android:textStyle="bold" android:layout_marginBottom="4dp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Version 1.0.1 " android:textColor="#AAAAAA" android:textSize="14sp" android:layout_marginBottom="48dp"/>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@drawable/bg_home_item" android:orientation="vertical" android:gravity="center" android:paddingVertical="24dp" android:layout_marginBottom="48dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="意见反馈 / 交流 QQ" android:textColor="#AAAAAA" android:textSize="14sp" android:layout_marginBottom="8dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="7586380" android:textColor="#E6E0E9" android:textSize="28sp" android:textStyle="bold" android:letterSpacing="0.1"/>
        </LinearLayout>

        <!-- 版权声明 -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Copyright © 2026\nShen Yue. All rights reserved." android:textColor="#555555" android:textSize="12sp" android:gravity="center" android:lineSpacingExtra="4dp"/>
    </LinearLayout>

</FrameLayout>